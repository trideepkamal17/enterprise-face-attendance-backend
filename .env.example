# Copy this file to backend/.env and update values as per environment.

# LOCAL DEVELOPMENT
NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:root@localhost:5432/enterprise_attendance1
DATABASE_SSL=0
DB_POOL_MAX=20
AI_SERVICE_URL=http://127.0.0.1:8001
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=change_this_local_secret_minimum_32_characters
JWT_EXPIRES_IN=12h
MATCH_THRESHOLD=0.48
DUPLICATE_BLOCK_SECONDS=30
LIVENESS_REQUIRED=1
LIVENESS_MIN_MOVEMENT=0.012
LIVENESS_MIN_AREA_CHANGE=0.012
GEOFENCE_REQUIRED=1
JSON_BODY_LIMIT=30mb

# PRODUCTION - yourstaffing.online
# Comment local values above and uncomment/update these on the server.
# NODE_ENV=production
# PORT=5000
# DATABASE_URL=postgresql://attendance_user:CHANGE_STRONG_PASSWORD@127.0.0.1:5432/enterprise_attendance
# DATABASE_SSL=0
# DB_POOL_MAX=30
# AI_SERVICE_URL=http://127.0.0.1:8001
# CLIENT_URLS=https://yourstaffing.online,https://www.yourstaffing.online
# JWT_SECRET=CHANGE_TO_A_LONG_RANDOM_64_CHARACTER_SECRET_BEFORE_PRODUCTION
# JWT_EXPIRES_IN=12h
